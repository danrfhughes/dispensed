<%= form_with model: medication, class: "space-y-4" do |f| %>
  <% if medication.errors.any? %>
    <div class="p-3 bg-red-100 text-red-700 rounded text-sm">
      <% medication.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :name, class: "w-full border border-gray-300 rounded px-3 py-2 text-sm" %>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :dose, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :dose, class: "w-full border border-gray-300 rounded px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :form, "Form (tablet, capsule, etc.)", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :form, class: "w-full border border-gray-300 rounded px-3 py-2 text-sm" %>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :start_date, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.date_field :start_date, class: "w-full border border-gray-300 rounded px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :days_supply, "Days supply (default 28)", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :days_supply, class: "w-full border border-gray-300 rounded px-3 py-2 text-sm" %>
    </div>
  </div>

  <div>
    <%= f.label :last_dispensed_on, "Last dispensed on", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.date_field :last_dispensed_on, class: "w-full border border-gray-300 rounded px-3 py-2 text-sm" %>
  </div>

  <div>
    <%= f.label :notes, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :notes, rows: 3, class: "w-full border border-gray-300 rounded px-3 py-2 text-sm" %>
  </div>

  <%= f.submit class: "text-white px-4 py-2 rounded text-sm cursor-pointer", style: "background-color: #5B8A7A;" %>
<% end %>
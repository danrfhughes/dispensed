<div class="max-w-lg">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-semibold text-gray-800">Dispensing pharmacy</h1>
    <%= link_to "Edit", edit_pharmacy_path, class: "text-sm text-blue-600 hover:underline" %>
  </div>

  <div class="bg-white border border-gray-200 rounded-lg divide-y divide-gray-100">
    <div class="px-4 py-3">
      <p class="text-xs text-gray-400 mb-0.5">Name</p>
      <p class="text-sm text-gray-800 font-medium"><%= @pharmacy.name %></p>
    </div>

    <% if @pharmacy.address.present? %>
      <div class="px-4 py-3">
        <p class="text-xs text-gray-400 mb-0.5">Address</p>
        <p class="text-sm text-gray-800 whitespace-pre-line"><%= @pharmacy.address %></p>
      </div>
    <% end %>

    <% if @pharmacy.phone.present? %>
      <div class="px-4 py-3">
        <p class="text-xs text-gray-400 mb-0.5">Phone</p>
        <p class="text-sm text-gray-800"><%= link_to @pharmacy.phone, "tel:#{@pharmacy.phone}", class: "text-blue-600 hover:underline" %></p>
      </div>
    <% end %>

    <% if @pharmacy.email.present? %>
      <div class="px-4 py-3">
        <p class="text-xs text-gray-400 mb-0.5">Email</p>
        <p class="text-sm text-gray-800"><%= link_to @pharmacy.email, "mailto:#{@pharmacy.email}", class: "text-blue-600 hover:underline" %></p>
      </div>
    <% end %>
  </div>
</div>

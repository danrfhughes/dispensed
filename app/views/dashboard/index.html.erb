<div class="space-y-6">

  <% if @medications_needing_reorder.any? %>
    <div class="bg-red-50 border border-red-200 rounded p-4">
      <p class="text-sm font-medium text-red-700 mb-2">⚠ Reorder overdue</p>
      <% @medications_needing_reorder.each do |med| %>
        <div class="flex justify-between items-center text-sm text-red-600 py-1">
          <span><%= med.name %> <%= med.dose %></span>
          <%= link_to "Order repeat →", "https://www.nhsapp.service.nhs.uk/", target: "_blank", class: "text-blue-600 hover:underline font-medium" %>
        </div>
      <% end %>
    </div>
  <% end %>

  <div>
    <h1 class="text-2xl font-semibold text-gray-800 mb-1">Today's doses</h1>
    <p class="text-sm text-gray-500 mb-4"><%= Date.current.strftime("%A, %-d %B %Y") %></p>

    <% if @today_doses.empty? %>
      <div class="bg-white rounded border border-gray-200 px-4 py-6 text-center text-gray-400 text-sm">
        No doses scheduled for today.
        <%= link_to "Check your medications", medications_path, class: "text-blue-600 hover:underline" %>.
      </div>
    <% else %>
      <div class="space-y-2">
        <% @today_doses.each do |dose| %>
          <div class="bg-white rounded border <%= dose.status == 'taken' ? 'border-green-200 bg-green-50' : dose.status == 'skipped' ? 'border-gray-100' : 'border-gray-200' %> px-4 py-3 flex justify-between items-center">
            <div>
              <div class="flex items-center gap-2">
                <%= link_to dose.medication.name, medication_path(dose.medication), class: "text-sm font-medium text-gray-800 hover:text-blue-600" %>
                <span class="text-xs text-gray-400"><%= dose.medication.dose %> · <%= dose.scheduled_for.strftime("%H:%M") %></span>
              </div>
              <% if dose.schedule.instructions.present? %>
                <p class="text-xs text-gray-400 mt-0.5"><%= dose.schedule.instructions %></p>
              <% end %>
            </div>

            <div class="flex items-center gap-3 text-sm">
              <% if dose.status == "pending" %>
                <%= button_to "Taken", take_dose_path(dose), method: :patch, class: "bg-green-600 text-white px-3 py-1 rounded text-xs hover:bg-green-700" %>
                <%= button_to "Skip", skip_dose_path(dose), method: :patch, class: "text-gray-400 hover:text-gray-600 text-xs" %>
              <% elsif dose.status == "taken" %>
                <span class="text-green-600 text-xs font-medium">✓ Taken <%= dose.taken_at.strftime("%H:%M") %></span>
              <% elsif dose.status == "skipped" %>
                <span class="text-gray-400 text-xs">Skipped</span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="pt-4 border-t border-gray-100">
    <%= link_to "My medications →", medications_path, class: "text-sm text-blue-600 hover:underline" %>
  </div>

</div>
<%# Date / time banner %>
<div class="bg-white border border-gray-200 rounded-lg px-6 py-6 mb-6">
  <div class="text-4xl font-bold text-gray-800 tabular-nums" id="live-time">--:--</div>
  <div class="text-lg text-gray-500 mt-1"><%= Date.current.strftime("%A, %-d %B %Y") %></div>
  <% if @prescriptions_expiring.any? %>
    <div class="mt-3 flex flex-wrap gap-x-4 gap-y-1">
      <% @prescriptions_expiring.each do |p| %>
        <% days = p[:days]; med = p[:med] %>
        <span class="text-sm <%= days <= 7 ? 'text-red-600 font-medium' : days <= 14 ? 'text-orange-500' : 'text-gray-400' %>">
          <%= med.name %> —
          <% if days <= 0 %>
            prescription ended
          <% elsif days == 1 %>
            1 day remaining
          <% else %>
            <%= days %> days remaining
          <% end %>
        </span>
      <% end %>
    </div>
  <% end %>
</div>

<script>
  function updateTime() {
    const now = new Date();
    const h = String(now.getHours()).padStart(2, '0');
    const m = String(now.getMinutes()).padStart(2, '0');
    document.getElementById('live-time').textContent = `${h}:${m}`;
  }
  updateTime();
  setInterval(updateTime, 60000);
</script>

<%# Reorder alerts %>
<% if @medications_needing_reorder.any? %>
  <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
    <p class="text-sm font-medium text-red-700 mb-2">⚠ Reorder overdue</p>
    <% @medications_needing_reorder.each do |med| %>
      <div class="flex justify-between items-center text-sm text-red-600 py-1">
        <span><%= med.name %> <%= med.dose %></span>
        <%= link_to "Order repeat →", "https://www.nhsapp.service.nhs.uk/", target: "_blank", class: "text-blue-600 hover:underline font-medium" %>
      </div>
    <% end %>
  </div>
<% end %>

<%# Weekly schedule grid %>
<div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-gray-200 bg-gray-50">
          <th class="text-left px-4 py-3 text-gray-600 font-medium w-52">Medication</th>
          <% @week_days.each do |day| %>
            <th class="px-3 py-3 text-center font-medium min-w-[72px] <%= day == Date.current ? 'bg-blue-50 text-blue-700' : 'text-gray-500' %>">
              <div class="text-xs uppercase tracking-wide"><%= day.strftime("%a") %></div>
              <div class="text-base font-semibold"><%= day.strftime("%-d") %></div>
            </th>
          <% end %>
        </tr>
      </thead>
      <tbody>
        <% if @medications.empty? %>
          <tr>
            <td colspan="8" class="px-4 py-10 text-center text-gray-400 text-sm">
              No medications added yet.
              <%= link_to "Add one →", new_medication_path, class: "text-blue-600 hover:underline" %>
            </td>
          </tr>
        <% else %>
          <% @medications.each do |med| %>
            <% today_pending = (@week_doses[[med.id, Date.current]] || []).find { |d| d.status == "pending" } %>
            <tr class="border-b border-gray-100 last:border-0">

              <%# Medication name cell %>
              <td class="px-4 py-3 align-top">
                <%= link_to med.name, medication_path(med), class: "font-medium text-gray-800 hover:text-blue-600" %>
                <div class="text-xs text-gray-400 mt-0.5"><%= med.dose %></div>

                <% if today_pending %>
                  <%= button_to "Take dose", take_dose_path(today_pending), method: :patch,
                      form: { data: { turbo_confirm: "Taken #{med.name} #{med.dose}?" } },
                      class: "mt-2 bg-green-600 text-white px-3 py-1 rounded text-xs hover:bg-green-700 cursor-pointer w-full" %>
                <% end %>

                <% active_schedules = med.schedules.active %>
                <div class="mt-2">
                  <% if active_schedules.any? %>
                    <% active_schedules.each do |s| %>
                      <div class="flex items-center gap-1">
                        <span class="text-xs text-gray-400"><%= s.days_label %></span>
                        <span class="text-gray-200 text-xs">·</span>
                        <%= link_to "Edit", edit_medication_schedule_path(med, s), class: "text-xs text-blue-500 hover:underline" %>
                      </div>
                    <% end %>
                  <% else %>
                    <%= link_to "+ Add schedule", new_medication_schedule_path(med), class: "text-xs text-blue-500 hover:underline" %>
                  <% end %>
                </div>
              </td>

              <%# Day cells %>
              <% @week_days.each do |day| %>
                <% doses = @week_doses[[med.id, day]] || [] %>
                <% times = med.schedules.active.select { |s| s.active_on?(day) }.map { |s| s.time_of_day.strftime("%H:%M") }.sort %>
                <%
                  cell_bg = if doses.any? { |d| d.status == "taken" }
                    "bg-green-100"
                  elsif doses.any? { |d| d.status == "skipped" }
                    "bg-orange-100"
                  elsif day == Date.current
                    "bg-blue-50"
                  else
                    ""
                  end
                %>
                <td class="px-3 py-3 text-center align-middle <%= cell_bg %>">
                  <% if times.any? %>
                    <% times.each do |t| %>
                      <div class="text-xs font-medium text-gray-700"><%= t %></div>
                    <% end %>
                  <% else %>
                    <span class="text-gray-200">–</span>
                  <% end %>
                </td>
              <% end %>

            </tr>
          <% end %>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<div class="pt-4 border-t border-gray-100 mt-6">
  <%= link_to "My medications →", medications_path, class: "text-sm text-blue-600 hover:underline" %>
</div>

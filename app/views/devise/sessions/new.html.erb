<div class="max-w-sm mx-auto mt-8">
  <div class="bg-white border border-gray-200 rounded-lg px-8 py-8">
    <h1 class="text-xl font-semibold text-gray-800 mb-6">Log in</h1>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="mb-4">
        <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-teal-500" %>
      </div>

      <div class="mb-4">
        <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :password, autocomplete: "current-password",
            class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-teal-500" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="mb-4 flex items-center gap-2">
          <%= f.check_box :remember_me, class: "rounded border-gray-300" %>
          <%= f.label :remember_me, class: "text-sm text-gray-600" %>
        </div>
      <% end %>

      <%= f.submit "Log in", class: "w-full text-white px-4 py-2 rounded text-sm font-medium cursor-pointer", style: "background-color: #5B8A7A;" %>
    <% end %>

    <% if devise_mapping.omniauthable? && resource_class.omniauth_providers.include?(:nhslogin) %>
      <div class="mt-6 pt-6 border-t border-gray-200">
        <p class="text-sm text-gray-500 text-center mb-3">or</p>
        <%= button_to "Continue with NHS Login",
              user_nhslogin_omniauth_authorize_path,
              method: :post,
              data: { turbo: false },
              class: "w-full text-white px-4 py-3 rounded text-sm font-semibold cursor-pointer",
              style: "background-color: #005eb8;" %>
      </div>
    <% end %>
  </div>

  <div class="mt-4 text-center text-sm text-gray-500 space-y-1">
    <%= render "devise/shared/links" %>
  </div>
</div>

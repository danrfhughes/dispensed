<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Dispensed" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Dispensed">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 min-h-screen">
  <nav class="px-6 py-4 flex justify-between items-center" style="background-color: #5B8A7A;">
    <a href="/" class="text-xl font-semibold text-white">Dispensed</a>
    <div class="flex gap-4 text-sm">
      <% if user_signed_in? %>
        <%= link_to "Dashboard", dashboard_path, class: "text-sm #{current_page?(dashboard_path) ? 'text-white font-semibold underline underline-offset-4' : 'text-white/80 hover:text-white'}" %>
        <%= link_to "Medications", medications_path, class: "text-sm #{current_page?(medications_path) ? 'text-white font-semibold underline underline-offset-4' : 'text-white/80 hover:text-white'}" %>
        <%= link_to "Adherence", adherence_path, class: "text-sm #{current_page?(adherence_path) ? 'text-white font-semibold underline underline-offset-4' : 'text-white/80 hover:text-white'}" %>
        <span class="text-white/40 text-sm">|</span>
        <span class="text-white/70 text-sm"><%= current_user.email %></span>
        <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-white/60 hover:text-white text-sm" %>
      <% else %>
        <%= link_to "Sign in", new_user_session_path, class: "text-white/80 hover:text-white" %>
        <%= link_to "Sign up", new_user_registration_path, class: "text-white/80 hover:text-white" %>
      <% end %>
    </div>
  </nav>

  <main class="max-w-4xl mx-auto px-6 py-8">
    <% flash.each do |type, msg| %>
      <div class="mb-4 p-3 rounded text-sm <%= type == 'alert' ? 'bg-red-100 text-red-700' : 'bg-green-100 text-green-700' %>">
        <%= msg %>
      </div>
    <% end %>
    <%= yield %>
  </main>
</body>
</html>
